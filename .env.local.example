# ========== LLM 配置 ==========
# 模型提供商：minimax / deepseek / qwen / openai / claude / custom
LLM_PROVIDER=minimax
# API Key（必填）
LLM_API_KEY=
# 自定义模型名（可选，覆盖默认值）
# LLM_MODEL=
# 自定义 API 地址（可选，custom 时必填）
# LLM_BASE_URL=

# ========== 飞书配置 ==========
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
